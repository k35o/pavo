{
  "type": "object",
  "required": ["summary", "verdict", "comments"],
  "additionalProperties": false,
  "properties": {
    "summary": {
      "type": "string",
      "description": "PR 全体のレビューサマリ（Markdown）"
    },
    "verdict": {
      "type": "string",
      "enum": ["approve", "comment"]
    },
    "comments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "line", "severity", "confidence", "body"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string" },
          "line": { "type": "integer" },
          "side": { "type": "string", "enum": ["LEFT", "RIGHT"] },
          "start_line": { "type": "integer" },
          "start_side": { "type": "string", "enum": ["LEFT", "RIGHT"] },
          "severity": {
            "type": "string",
            "enum": ["critical", "warning", "suggestion", "praise"]
          },
          "confidence": { "type": "integer", "minimum": 0, "maximum": 100 },
          "body": { "type": "string" },
          "suggestion": { "type": "string" }
        }
      }
    },
    "resolved_comment_ids": {
      "type": "array",
      "items": { "type": "integer" }
    }
  }
}
